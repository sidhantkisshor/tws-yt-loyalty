# YT Loyalty - Environment Variables Template
# Copy this file to .env.local and fill in the values

# ============================================
# DATABASE CONFIGURATION
# ============================================

# Supabase PostgreSQL connection with PgBouncer (for runtime queries)
# Format: postgresql://user:password@host:6543/database?pgbouncer=true
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.xxxxx.supabase.co:6543/postgres?pgbouncer=true"

# Direct PostgreSQL connection (for migrations - bypasses PgBouncer)
# Format: postgresql://user:password@host:5432/database
DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.xxxxx.supabase.co:5432/postgres"

# ============================================
# NEXTAUTH CONFIGURATION
# ============================================

# Your application URL (use http://localhost:3000 for development)
# In production, this should be your actual domain: https://your-domain.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# Secret for signing JWT tokens (MUST be 32+ characters)
# Generate with: openssl rand -base64 32
# IMPORTANT: Never use the placeholder value in production!
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# ============================================
# ADMIN ACCESS CONTROL
# ============================================

# Comma-separated list of email addresses allowed to access admin dashboard
# Example: "admin@example.com,manager@example.com"
ADMIN_EMAILS="your-email@example.com"

# ============================================
# GOOGLE OAUTH CREDENTIALS
# ============================================

# Google OAuth Client ID from Google Cloud Console
# Used for: Admin authentication and YouTube API access
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"

# Google OAuth Client Secret from Google Cloud Console
GOOGLE_CLIENT_SECRET="GOCSPX-your-client-secret"

# ============================================
# UPSTASH REDIS CONFIGURATION
# ============================================

# Upstash Redis REST URL
# Get from: https://console.upstash.com
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"

# Upstash Redis REST Token
UPSTASH_REDIS_REST_TOKEN="your-redis-token"

# ============================================
# CRON JOB SECURITY
# ============================================

# Secret for authenticating cron job requests (Bearer token)
# Generate with: openssl rand -base64 32
# Secures all /api/cron/* endpoints:
#   poll-streams (*/3 min)    - Live chat ingestion
#   ingest-comments (*/15 min) - Video comment ingestion
#   fulfill-rewards (*/5 min) - Digital reward delivery
#   token-health (hourly)     - OAuth token monitoring
#   discover-videos (*/4 hrs) - New video discovery
#   update-segments (*/6 hrs) - Fan segmentation
#   daily-scoring (2 AM UTC)  - Point settlement
#   fraud-scan (3 AM UTC)     - Fraud review + enforcement
#   tier-decay (midnight UTC) - Rank decay
CRON_SECRET="generate-with-openssl-rand-base64-32"

# ============================================
# SENTRY MONITORING (OPTIONAL)
# ============================================

# Sentry DSN for error tracking
# Get from: https://sentry.io/settings/projects/YOUR_PROJECT/keys/
# SENTRY_DSN="https://xxxxx@xxxxx.ingest.sentry.io/xxxxx"

# Sentry authentication token for build-time integration
# Get from: https://sentry.io/settings/account/api/auth-tokens/
# SENTRY_AUTH_TOKEN="your-sentry-auth-token"

# Sentry organization slug
# SENTRY_ORG="your-org-slug"

# Sentry project slug
# SENTRY_PROJECT="your-project-slug"

# ============================================
# ENVIRONMENT MODE
# ============================================

# Application environment: development | production | test
NODE_ENV="development"

# ============================================
# YOUTUBE API CONFIGURATION (OPTIONAL)
# ============================================

# Daily quota limit for YouTube API calls (default: 10000)
# Adjust based on your Google Cloud quota allocation
# YOUTUBE_DAILY_QUOTA_LIMIT="10000"
